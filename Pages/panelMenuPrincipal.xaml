<Page x:Class="OdinTools.Pages.panelMenuPrincipal"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OdinTools.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1280"
      Title="panelMenuPrincipal">

    <Page.Resources>
        <FontFamily x:Key="FuenteJohn">pack://application:,,,/res/fonts/#Muro Regular</FontFamily>
        <FontFamily x:Key="FuenteJohnInclinada">pack://application:,,,/res/fonts/#Muro Slant</FontFamily>

        <!--BUTTON STYLE WITH GLOW EFFECT-->
        <Style x:Key="GlowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#00D4FF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect Color="#00D4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A00D4FF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00E5FF"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00E5FF" BlurRadius="16" ShadowDepth="0" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00D4FF"/>
                                <Setter Property="Foreground" Value="#0A0E17"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--GLASS CARD STYLE-->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#1A00D4FF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#3300D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <Grid Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!--WELCOME HEADER-->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Welcome to" Grid.Column="0" Foreground="#88CCFF" FontSize="80" FontFamily="{StaticResource FuenteJohnInclinada}"
                        Grid.Row="0" TextAlignment="Left" VerticalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="⚡ Odin Tools ⚡" Grid.Column="0" Foreground="#00D4FF" FontSize="50" FontFamily="{StaticResource FuenteJohnInclinada}"
                        Grid.Row="1" TextAlignment="Left" VerticalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>

            <!--DISCORD CARD-->
            <Border Grid.Column="1" Grid.RowSpan="2" CornerRadius="12" Padding="15" Margin="30,20,20,0" Width="280" Height="130">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A2A3A" Offset="0.0"/>
                        <GradientStop Color="#0D1B2A" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00D4FF" Offset="0.0"/>
                        <GradientStop Color="Transparent" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1.5</Border.BorderThickness>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Width="70" Height="70" Source="/res/media/icons/ico.ico" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Join Our Server" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,6" HorizontalAlignment="Right"/>
                        <TextBlock Text="The official Odin Tools community" FontSize="12" Foreground="#88BBDD" Margin="0,0,0,12" 
                                   TextAlignment="Right" HorizontalAlignment="Right"/>
                        <Button Content="Join Now" Width="110" Height="26" Foreground="White"
                                FontWeight="Bold" FontSize="13" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Click="joinServerClick">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="#00863a" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#00AA44"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        
        <!--PROMO / FEATURED SECTION-->
        <Grid Grid.Row="1" Margin="0,30,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Featured" Foreground="White" FontSize="28" FontFamily="{StaticResource FuenteJohnInclinada}"
                       Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,15">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!--PROMO IMAGE-->
            <Grid Grid.Row="1" HorizontalAlignment="Left">
                <Border CornerRadius="12" Width="840" Height="220" BorderBrush="#2200D4FF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
                    </Border.Effect>
                    <Image x:Name="imagenPromo" Stretch="UniformToFill"/>
                </Border>
            </Grid>
        </Grid>

        <!--ACTION BUTTONS-->
        <Grid Grid.Row="2" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--NAVIGATION BUTTONS-->
            <Grid Grid.Row="0" Width="750" Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top"
                        Content="Quick Guide" Style="{StaticResource GlowButton}" Click="quickGuideButtonClick"/>
                <Button Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                        Content="Changelog" Style="{StaticResource GlowButton}" Click="changeLogButtonClick"/>
                <Button Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Top"
                        Content="Legal Notice" Style="{StaticResource GlowButton}" Click="legalButtonClick"/>
                <Button Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Top"
                        Content="Donate" Style="{StaticResource GlowButton}" Click="donate_click"/>
            </Grid>

            <!--SPONSORS SECTION-->
            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Sponsors" Foreground="#88BBDD" FontSize="18" FontFamily="{StaticResource FuenteJohnInclinada}"
                            Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0"/>

                <Image Grid.Row="1" Name="imagenSponsor" Width="350" Height="60" Margin="0,10,0,0" VerticalAlignment="Top"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
