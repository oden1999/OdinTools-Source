<Window x:Class="OdinTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:classes="clr-namespace:OdinTools.Classes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:usercontrols="clr-namespace:OdinTools.UserControls"
        xmlns:local="clr-namespace:OdinTools"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Icon="/res/media/icons/ico.ico"
        WindowStartupLocation="CenterScreen"
        Title="⚡ Odin Tools ⚡" Height="840" Width="1420"
        MinHeight="740" MinWidth="1060">

    <Window.Resources>
        <!--STYLES FOR SIDEBAR BUTTONS-->
        <Style x:Key="BotonLateral" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="5,2">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A3347"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00D4FF"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0D2233"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--Glassmorphism Border Style-->
        <Style x:Key="GlassBorder" TargetType="Border">
            <Setter Property="Background" Value="#CC1A1A2E"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderBrush" Value="#3300D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00D4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <classes:ExpandTextConverter x:Key="ExpandTextConverter"/>
    </Window.Resources>
    
    <Grid>
        <!--CYAN/BLUE GRADIENT BACKGROUND-->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0E17" Offset="0.0"/>
                <GradientStop Color="#0D1B2A" Offset="0.5"/>
                <GradientStop Color="#0A1628" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!--BACKGROUND VIDEO-->
        <MediaElement Name="BackgroundVideo" 
                      Source="res/media/backgrounds/red_porsche.mp4"
                      LoadedBehavior="Manual" 
                      UnloadedBehavior="Manual" 
                      IsMuted="True" 
                      Stretch="UniformToFill" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" 
                      MediaFailed="BackgroundVideo_MediaFailed"
                      MediaEnded="BackgroundVideo_MediaEnded" />

        <!--MAIN BORDER WITH GLASS EFFECT-->
        <Border Margin="12,12,12,12" CornerRadius="15" BorderBrush="#2200D4FF" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush Opacity="0.75">
                    <GradientStop Color="#AA0D1B2A" Offset="0.0"/>
                    <GradientStop Color="#AA0A1628" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--HEADER-->
                <usercontrols:Cabecera x:Name="Cabecera" Grid.Row="0" Grid.Column="1" Margin="0,10,0,0"/>

                <!--MAIN CONTENT AREA-->
                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <Frame x:Name="framePrincipal" Grid.Row="0" Source="/Pages/panelMenuPrincipal.xaml" NavigationUIVisibility="Hidden" Background="Transparent"/>

                    <!--FOOTER-->
                    <Grid Grid.Row="1" HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Created by: ♡ Odin Tools Team ♡" Foreground="#FF88BBDD" FontSize="11"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="Version: " Foreground="#FF88BBDD" FontSize="11" Name="txtVersion"
                                   FontFamily="Segoe UI" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                    </Grid>
                </Grid>
                
                <!--SIDEBAR-->
                <Border x:Name="Sidebar" Grid.RowSpan="2" Grid.Column="0" 
                        Background="#0D1520" CornerRadius="10,0,0,10" Padding="10"
                        Width="60" HorizontalAlignment="Left"
                        BorderBrush="#1100D4FF" BorderThickness="0,0,2,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#00D4FF" BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
                    </Border.Effect>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="160" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                 To="60" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--TOP BUTTONS-->
                        <StackPanel Orientation="Vertical" Grid.Row="0">
                            <!--HOME-->
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                <Button Style="{StaticResource BotonLateral}" Tag="Inicio" Width="140" Click="boton_home_presionado">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#00D4FF" Margin="5,12,0,12"/>
                                        <TextBlock Text="Home" Margin="12,0,0,0" VerticalAlignment="Center"
                                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                   Visibility="{Binding Width, ElementName=Sidebar, Converter={StaticResource ExpandTextConverter}}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Border Height="1" Background="#1A3347" Margin="5,5,5,5" Opacity="0.5"/>

                            <!--BYPASS-->
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                <Button Style="{StaticResource BotonLateral}" Tag="Bypass" Width="140" Click="bypassButtonClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#00D4FF" Margin="5,12,0,12"/>
                                        <TextBlock Text="Bypass" Margin="12,0,0,0" VerticalAlignment="Center"
                                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                   Visibility="{Binding Width, ElementName=Sidebar, Converter={StaticResource ExpandTextConverter}}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            
                            <!--ONLINE FIX-->
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                <Button Style="{StaticResource BotonLateral}" Tag="OnlineFix" Width="140" Click="onlineFixButtonClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE815;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#00D4FF" Margin="5,12,0,12"/>
                                        <TextBlock Text="OnlineFix" Margin="12,0,0,0" VerticalAlignment="Center"
                                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                   Visibility="{Binding Width, ElementName=Sidebar, Converter={StaticResource ExpandTextConverter}}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!--STEAMLESS-->
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                <Button Style="{StaticResource BotonLateral}" Tag="SteamLess" Width="140" Click="steamlessButtonClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7DF;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#00D4FF" Margin="7,12,0,12"/>
                                        <TextBlock Text="SteamLess" Margin="12,0,0,0" VerticalAlignment="Center"
                                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                   Visibility="{Binding Width, ElementName=Sidebar, Converter={StaticResource ExpandTextConverter}}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!--SETTINGS BUTTON AT BOTTOM-->
                        <StackPanel Orientation="Vertical" Grid.Row="1" HorizontalAlignment="Left">
                            <Border Height="1" Background="#1A3347" Margin="5,5,5,5" Opacity="0.5"/>
                            <Button Style="{StaticResource BotonLateral}" Width="140" Click="AjustesButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="#00D4FF" Margin="5,12,0,12"/>
                                    <TextBlock Text="Settings" Margin="12,0,0,0" VerticalAlignment="Center"
                                               Foreground="White" FontSize="14" FontWeight="SemiBold"
                                               Visibility="{Binding Width, ElementName=Sidebar, Converter={StaticResource ExpandTextConverter}}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!--Notification Canvas-->
        <Canvas x:Name="NotificationCanvas"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,10,10,0"
            IsHitTestVisible="False"/>
    </Grid>
</Window>
